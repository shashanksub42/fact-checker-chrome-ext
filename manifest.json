{
  "manifest_version": 3,
  "name": "FactCheckAI",
  "version": "1.0",
  "description": "Real-time AI fact checking for YouTube videos",

  "action": {
    "default_title": "FactCheckAI"
  },

  "side_panel": {
    "default_path": "index.html"
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"]
    }
  ],

  "permissions": ["storage", "sidePanel", "activeTab", "tabs"],

  "host_permissions": [
    "https://fact-checker-chrome-ext.onrender.com/*",
    "https://api.openai.com/*",
    "*://*.youtube.com/*"
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
